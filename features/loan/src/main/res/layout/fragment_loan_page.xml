<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@color/background_color"
    android:layout_height="match_parent">

    <loan.calculator.uikit.toolbar.LoanToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/_30sdp"
        app:layout_constraintStart_toStartOf="parent"
        app:loan_toolbar_option="without_left_and_right"
        app:loan_toolbar_title="@string/app_name"
        app:layout_constraintTop_toTopOf="parent"/>


    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/adView"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/_10sdp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/loan_amount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:background="@drawable/radius_8dp_white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/loan_amount_part"
                    android:layout_width="@dimen/_70sdp"
                    android:layout_height="0dp"
                    android:background="@drawable/item_background"
                    android:padding="@dimen/_18sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/loan_amount_image"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/ic_unlock"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>


                <TextView
                    android:id="@+id/loan_amount_textview"
                    style="@style/regular_caption1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginLeft="@dimen/_10sdp"
                    android:gravity="center_vertical"
                    android:textColor="@color/gray_text"
                    android:text="@string/loan_amount"
                    app:layout_constraintBottom_toBottomOf="@+id/loan_seperator"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/loan_amount_part"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/loan_seperator"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_1sdp"
                    android:background="@color/color_gray_two"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/loan_amount_part"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/loan_amount_currency"
                    style="@style/regular_caption2"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:background="@null"
                    android:gravity="center_vertical"
                    android:text="@string/common_currency_symbol"
                    android:textColor="@color/color_pure_black"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/loan_amount_textview"
                    app:layout_constraintTop_toBottomOf="@+id/loan_amount_textview" />


                <EditText
                    android:id="@+id/loan_amount_edittext"
                    style="@style/regular_caption2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="@dimen/_1sdp"
                    android:background="@null"
                    android:hint="@string/loan_hint_amount_example"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingVertical="@dimen/_6sdp"
                    android:paddingRight="@dimen/_10sdp"
                    android:textColor="@color/color_pure_black"
                    android:textColorHint="@color/color_pure_black"
                    android:textCursorDrawable="@drawable/input_text_cursor_color"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/loan_amount_currency"
                    app:layout_constraintTop_toBottomOf="@+id/loan_amount_textview" />


            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/loan_rate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@drawable/radius_8dp_white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/loan_amount">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/loan_rate_part"
                    android:layout_width="@dimen/_70sdp"
                    android:layout_height="0dp"
                    android:background="@drawable/item_background"
                    android:padding="@dimen/_18sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/loan_rate_image"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/ic_unlock"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>


                <TextView
                    android:id="@+id/loan_rate_textview"
                    style="@style/regular_caption1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:textColor="@color/gray_text"
                    android:layout_marginLeft="@dimen/_10sdp"
                    android:gravity="center_vertical"
                    android:text="@string/interest_rate"
                    app:layout_constraintBottom_toBottomOf="@+id/loan_rate_seperator"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/loan_rate_part"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/loan_rate_seperator"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_1sdp"
                    android:background="@color/color_gray_two"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/loan_rate_part"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/loan_rate_edittext"
                    style="@style/regular_caption2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="@string/loan_hint_rate_example"
                    android:imeOptions="actionDone"
                    android:inputType="numberDecimal"
                    android:maxLines="1"
                    android:paddingVertical="@dimen/_6sdp"
                    android:paddingRight="@dimen/_10sdp"
                    android:textColor="@color/color_pure_black"
                    android:textColorHint="@color/color_pure_black"
                    android:textCursorDrawable="@drawable/input_text_cursor_color"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/loan_rate_percentage"
                    app:layout_constraintStart_toStartOf="@+id/loan_rate_textview"
                    app:layout_constraintTop_toBottomOf="@+id/loan_rate_textview" />


                <TextView
                    android:id="@+id/loan_rate_percentage"
                    style="@style/regular_caption2"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_marginRight="@dimen/_5sdp"
                    android:gravity="center_vertical"
                    android:textColor="@color/color_pure_black"
                    android:text="@string/common_percent_symbol"
                    app:layout_constraintBottom_toBottomOf="@+id/loan_rate_edittext"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/loan_rate_edittext" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/loan_period"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@drawable/radius_8dp_white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/loan_rate">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/loan_period_part"
                    android:layout_width="@dimen/_70sdp"
                    android:layout_height="0dp"
                    android:background="@drawable/item_background"
                    android:padding="@dimen/_18sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/loan_period_image"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/ic_unlock"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>


                <TextView
                    android:id="@+id/loan_period_textview"
                    style="@style/regular_caption1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginLeft="@dimen/_10sdp"
                    android:gravity="center_vertical"
                    android:text="@string/loan_term"
                    android:textColor="@color/gray_text"
                    app:layout_constraintBottom_toBottomOf="@+id/loan_period_seperator"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/loan_period_part"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/loan_period_seperator"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_1sdp"
                    android:background="@color/color_gray_two"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/loan_period_part"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/year_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="@dimen/_8sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/year_month_view"
                    app:layout_constraintStart_toStartOf="@+id/loan_period_textview"
                    app:layout_constraintTop_toBottomOf="@+id/loan_period_textview">

                    <EditText
                        android:id="@+id/loan_year_edittext"
                        style="@style/regular_caption2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/loan_hint_year_example"
                        android:imeOptions="actionDone"
                        android:inputType="number"
                        android:maxLines="1"
                        android:paddingVertical="@dimen/_6sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:textColor="@color/color_pure_black"
                        android:textColorHint="@color/color_pure_black"
                        android:textCursorDrawable="@drawable/input_text_cursor_color"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/loan_year_textview"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/loan_year_textview"
                        style="@style/regular_caption2"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:textColor="@color/color_pure_black"
                        android:gravity="center_vertical"
                        android:text="@string/year"
                        app:layout_constraintBottom_toBottomOf="@+id/loan_year_edittext"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/loan_year_edittext" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <View
                    android:id="@+id/year_month_view"
                    android:layout_width="@dimen/_1sdp"
                    android:layout_height="0dp"
                    android:background="@color/color_gray_two"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="@+id/loan_period_textview"
                    app:layout_constraintTop_toBottomOf="@+id/loan_period_textview" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/month_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/_8sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/year_month_view"
                    app:layout_constraintTop_toBottomOf="@+id/loan_period_textview">

                    <EditText
                        android:id="@+id/loan_month_edittext"
                        style="@style/regular_caption2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/loan_hint_month_example"
                        android:imeOptions="actionDone"
                        android:inputType="number"
                        android:maxLines="1"
                        android:paddingVertical="@dimen/_6sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:textColor="@color/color_pure_black"
                        android:textColorHint="@color/color_pure_black"
                        android:textCursorDrawable="@drawable/input_text_cursor_color"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@+id/loan_month_textview"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/loan_month_textview"
                        style="@style/regular_caption2"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_marginRight="@dimen/_5sdp"
                        android:gravity="center_vertical"
                        android:text="@string/months"
                        android:textColor="@color/color_pure_black"
                        app:layout_constraintBottom_toBottomOf="@+id/loan_month_edittext"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/loan_month_edittext" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/loan_payment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:layout_marginTop="@dimen/_5sdp"
                android:background="@drawable/radius_8dp_white"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/loan_period">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/loan_payment_part"
                    android:layout_width="@dimen/_70sdp"
                    android:layout_height="0dp"
                    android:background="@drawable/item_background_color"
                    android:padding="@dimen/_18sdp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/loan_payment_image"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:src="@drawable/ic_lock"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>


                <TextView
                    android:id="@+id/loan_payment_textview"
                    style="@style/regular_caption1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginLeft="@dimen/_10sdp"
                    android:gravity="center_vertical"
                    android:text="@string/payment"
                    android:textColor="@color/gray_text"
                    app:layout_constraintBottom_toBottomOf="@+id/loan_payment_seperator"
                    app:layout_constraintEnd_toStartOf="@+id/type"
                    app:layout_constraintStart_toEndOf="@+id/loan_payment_part"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/loan_payment_seperator"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_1sdp"
                    android:background="@color/color_gray_two"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/type"
                    app:layout_constraintStart_toEndOf="@+id/loan_payment_part"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/loan_payment_currency"
                    style="@style/regular_caption2"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:gravity="center_vertical"
                    android:text="@string/common_currency_symbol"
                    android:textColor="@color/color_pure_black"
                    app:layout_constraintBottom_toBottomOf="@+id/loan_payment_part"
                    app:layout_constraintStart_toStartOf="@+id/loan_payment_textview"
                    app:layout_constraintTop_toBottomOf="@+id/loan_payment_textview" />


                <EditText
                    android:id="@+id/loan_payment_edittext"
                    style="@style/regular_caption2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/_1sdp"
                    android:background="@null"
                    android:hint="@string/loan_hint_payment_example"
                    android:imeOptions="actionDone"
                    android:inputType="number"
                    android:maxLines="1"
                    android:paddingVertical="@dimen/_6sdp"
                    android:paddingRight="@dimen/_10sdp"
                    android:textColor="@color/color_pure_black"
                    android:textColorHint="@color/color_pure_black"
                    android:textCursorDrawable="@drawable/input_text_cursor_color"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="@+id/loan_payment_seperator"
                    app:layout_constraintStart_toEndOf="@+id/loan_payment_currency"
                    app:layout_constraintTop_toBottomOf="@+id/loan_payment_textview" />


                <androidx.appcompat.widget.AppCompatSpinner
                    android:id="@+id/type"
                    style="@style/spinnerItemStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_margin="@dimen/_3sdp"
                    android:background="@drawable/bg_spinner"
                    android:drawSelectorOnTop="true"
                    android:entries="@array/loanItems"
                    android:gravity="center"
                    android:paddingRight="@dimen/_15sdp"
                    android:spinnerMode="dropdown"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraintLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:layout_marginTop="@dimen/_8sdp"
                android:background="@drawable/radius_8dp_white"
                android:padding="@dimen/_16sdp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/loan_payment">

                <TextView
                    android:id="@+id/total_interest_textview"
                    style="@style/regular_caption1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:textColor="@color/gray_text"
                    android:paddingHorizontal="@dimen/_4sdp"
                    android:text="@string/loan_result_interest_header"
                    app:layout_constraintEnd_toStartOf="@+id/total_repayment_textview"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/total_repayment_textview" />

                <LinearLayout
                    android:id="@+id/total_interest_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="@+id/total_interest_textview"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/total_interest_textview">

                    <TextView
                        android:id="@+id/total_interest_currency"
                        style="@style/bold_caption1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/common_currency_symbol" />


                    <TextView
                        android:id="@+id/total_interest_value"
                        style="@style/bold_caption1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/total_interest_currency"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="6 618.55" />


                </LinearLayout>

                <View
                    android:id="@+id/seperator_bottom"
                    android:layout_width="@dimen/_1sdp"
                    android:layout_height="0dp"
                    android:background="@color/gray"
                    app:layout_constraintBottom_toBottomOf="@+id/total_interest_container"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/total_repayment_textview" />


                <TextView
                    android:id="@+id/total_repayment_textview"
                    style="@style/regular_caption1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="1"
                    android:paddingHorizontal="@dimen/_4sdp"
                    android:textColor="@color/gray_text"
                    android:text="@string/total_repayment"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/total_interest_textview"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/total_repayment_container"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/total_interest_textview"
                    app:layout_constraintTop_toBottomOf="@+id/total_repayment_textview">

                    <TextView
                        android:id="@+id/total_repayment_currency"
                        style="@style/bold_caption1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/common_currency_symbol" />


                    <TextView
                        android:id="@+id/total_repayment_value"
                        style="@style/bold_caption1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        tools:text="106 618.55" />


                </LinearLayout>


                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/chart"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/_200sdp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/seperator_bottom" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>


    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_8sdp"
        app:adSize="BANNER"
        app:adUnitId="@string/admob_id"
        app:layout_constraintBottom_toTopOf="@+id/apply_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:visibility="visible" />

    <loan.calculator.uikit.button.LoanButton
        android:id="@+id/apply_button"
